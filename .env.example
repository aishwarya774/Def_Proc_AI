# HybridRAG Configuration
# Copy this to .env and edit as needed

# ── Ollama (install natively, not in Docker) ─────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_TIMEOUT=120

# ── OpenAI (optional — leave blank for offline-only mode) ────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Embedding Model ─────────────────────────────────────────
# Downloads automatically on first run (~90 MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2
